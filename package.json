{
  "name": "private-wp-plugin-base",
  "private": true,
  "scripts": {
    "wp-env:start": "wp-env start",
    "wp-env:cron-runner": "node tools/wp-env/attach-cron-runner.mjs",
    "wp-env:cron-runner:stop": "node tools/wp-env/stop-cron-runner.mjs",
    "wp-env:stop": "wp-env stop",
    "wp-env:destroy": "wp-env destroy",
    "wp-env:clean": "wp-env clean all",
    "lint:php": "composer run phpcs",
    "fix:php": "composer run phpcbf",
    "test:php": "composer run phpunit",
    "analyse:php": "composer run phpstan",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:wp-env": "node e2e/run-wp-env-tests.mjs",
    "test:e2e:install": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.49.0",
    "@wordpress/env": "^11.1.0"
  }
}
