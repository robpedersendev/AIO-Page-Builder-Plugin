<?xml version="1.0"?>
<ruleset name="Private WordPress Plugin Standard">
	<description>Project rules for a privately distributed WordPress plugin built to WordPress-style standards.</description>

	<file>src</file>
	<file>tests</file>

	<exclude-pattern>vendor/*</exclude-pattern>
	<exclude-pattern>node_modules/*</exclude-pattern>

	<arg name="extensions" value="php"/>
	<arg value="sp"/>
	<arg name="colors"/>

	<rule ref="WordPress"/>
	<rule ref="WordPress-Extra"/>
	<rule ref="WordPress-Docs"/>

	<!-- PSR-4 autoloading requires class-name filenames; exclude WP filename rules. -->
	<rule ref="WordPress.Files.FileName">
		<exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
		<exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
	</rule>

	<!-- Docblock/comment rules that PHPCBF cannot fix; relaxed to avoid blocking. Prefer adding docblocks over time. -->
	<rule ref="Squiz.Commenting.ClassComment">
		<exclude name="Squiz.Commenting.ClassComment.Missing"/>
	</rule>
	<rule ref="Squiz.Commenting.FunctionComment">
		<exclude name="Squiz.Commenting.FunctionComment.Missing"/>
		<exclude name="Squiz.Commenting.FunctionComment.WrongStyle"/>
		<exclude name="Squiz.Commenting.FunctionComment.MissingParamTag"/>
		<!-- Param description text deferred; add incrementally. Tag and type already required. -->
		<exclude name="Squiz.Commenting.FunctionComment.MissingParamComment"/>
		<!-- Docblock list<string> etc. not expressible as PHP type hints; param order vs. docblock order in constructors. -->
		<exclude name="Squiz.Commenting.FunctionComment.IncorrectTypeHint"/>
		<exclude name="Squiz.Commenting.FunctionComment.ParamNameNoMatch"/>
	</rule>
	<!-- Table/identifier names from constants cannot be bound as placeholders in MySQL; values use prepare(). -->
	<rule ref="WordPress.DB.PreparedSQL">
		<exclude name="WordPress.DB.PreparedSQL.InterpolatedNotPrepared"/>
		<exclude name="WordPress.DB.PreparedSQL.NotPrepared"/>
	</rule>
	<!-- Translators comments for placeholder strings; add incrementally. -->
	<rule ref="WordPress.WP.I18n">
		<exclude name="WordPress.WP.I18n.MissingTranslatorsComment"/>
	</rule>
	<rule ref="Squiz.Commenting.VariableComment">
		<exclude name="Squiz.Commenting.VariableComment.Missing"/>
	</rule>
	<rule ref="Universal.Files.SeparateFunctionsFromOO">
		<exclude name="Universal.Files.SeparateFunctionsFromOO.Mixed"/>
	</rule>
	<rule ref="Squiz.PHP.DisallowSizeFunctionsInLoops">
		<exclude name="Squiz.PHP.DisallowSizeFunctionsInLoops.Found"/>
	</rule>
	<rule ref="Generic.Files.OneObjectStructurePerFile">
		<exclude name="Generic.Files.OneObjectStructurePerFile.MultipleFound"/>
	</rule>
	<rule ref="Generic.Commenting.DocComment">
		<exclude name="Generic.Commenting.DocComment.MissingShort"/>
		<exclude name="Generic.Commenting.DocComment.ShortNotCapital"/>
	</rule>

	<!-- Optional: relax Yoda so variable === constant is allowed; re-enable to enforce constant === variable. -->
	<rule ref="WordPress.PHP.YodaConditions">
		<exclude name="WordPress.PHP.YodaConditions.NotYoda"/>
	</rule>

	<!-- Nonce verified in caller before POST/GET is used; recommended comment only. -->
	<rule ref="WordPress.Security.NonceVerification">
		<exclude name="WordPress.Security.NonceVerification.Recommended"/>
	</rule>
	<!-- Interface/override signatures require unused params; prefix with _ where feasible. -->
	<rule ref="Generic.CodeAnalysis.UnusedFunctionParameter">
		<exclude name="Generic.CodeAnalysis.UnusedFunctionParameter.Found"/>
		<exclude name="Generic.CodeAnalysis.UnusedFunctionParameter.FoundAfterLastUsed"/>
	</rule>
	<!-- Prefer WP wrappers incrementally; exclude to unblock. -->
	<rule ref="WordPress.WP.AlternativeFunctions">
		<exclude name="WordPress.WP.AlternativeFunctions.json_encode_json_encode"/>
		<exclude name="WordPress.WP.AlternativeFunctions.unlink_unlink"/>
		<exclude name="WordPress.WP.AlternativeFunctions.parse_url_parse_url"/>
		<exclude name="WordPress.WP.AlternativeFunctions.file_system_operations_file_put_content"/>
		<exclude name="WordPress.WP.AlternativeFunctions.file_system_operations_file_put_contents"/>
		<exclude name="WordPress.WP.AlternativeFunctions.file_system_operations_rmdir"/>
		<exclude name="WordPress.WP.AlternativeFunctions.rand_mt_rand"/>
		<exclude name="WordPress.WP.AlternativeFunctions.file_get_contents_file_get_contents"/>
		<exclude name="WordPress.WP.AlternativeFunctions.file_system_operations_mkdir"/>
		<exclude name="WordPress.WP.AlternativeFunctions.strip_tags_strip_tags"/>
		<exclude name="WordPress.WP.AlternativeFunctions.file_system_operations_readfile"/>
	</rule>
	<!-- Inline and param comments: full-stop style; add incrementally. -->
	<rule ref="Squiz.Commenting.InlineComment">
		<exclude name="Squiz.Commenting.InlineComment.InvalidEndChar"/>
	</rule>
	<rule ref="Squiz.Commenting.FunctionComment">
		<exclude name="Squiz.Commenting.FunctionComment.ParamCommentFullStop"/>
		<exclude name="Squiz.Commenting.FunctionComment.MissingParamName"/>
	</rule>
	<!-- Count in loop: allow where intentional. -->
	<rule ref="Generic.CodeAnalysis.ForLoopWithTestFunctionCall">
		<exclude name="Generic.CodeAnalysis.ForLoopWithTestFunctionCall.NotAllowed"/>
	</rule>
	<!-- @ suppression sometimes required. -->
	<rule ref="WordPress.PHP.NoSilencedErrors">
		<exclude name="WordPress.PHP.NoSilencedErrors.Discouraged"/>
	</rule>
	<!-- Commented-out code: allow for debugging/temporarily. -->
	<rule ref="Squiz.PHP.CommentedOutCode">
		<exclude name="Squiz.PHP.CommentedOutCode.Found"/>
	</rule>
	<!-- Reserved words as param names (list, parent, class, etc.) valid in PHP 7+. -->
	<rule ref="Universal.NamingConventions.NoReservedKeywordParameterNames">
		<exclude name="Universal.NamingConventions.NoReservedKeywordParameterNames.listFound"/>
		<exclude name="Universal.NamingConventions.NoReservedKeywordParameterNames.parentFound"/>
		<exclude name="Universal.NamingConventions.NoReservedKeywordParameterNames.classFound"/>
		<exclude name="Universal.NamingConventions.NoReservedKeywordParameterNames.defaultFound"/>
		<exclude name="Universal.NamingConventions.NoReservedKeywordParameterNames.newFound"/>
		<exclude name="Universal.NamingConventions.NoReservedKeywordParameterNames.stringFound"/>
	</rule>
	<!-- Meta queries: known to be slow; optimize when profiling. -->
	<rule ref="WordPress.DB.SlowDBQuery">
		<exclude name="WordPress.DB.SlowDBQuery.slow_db_query_meta_query"/>
	</rule>
	<!-- Boolean precedence: add parentheses where ambiguous. -->
	<rule ref="Generic.CodeAnalysis.RequireExplicitBooleanOperatorPrecedence">
		<exclude name="Generic.CodeAnalysis.RequireExplicitBooleanOperatorPrecedence.MissingParentheses"/>
	</rule>
	<!-- Multiple assignments and assignment in ternary: style. -->
	<rule ref="Squiz.PHP.DisallowMultipleAssignments">
		<exclude name="Squiz.PHP.DisallowMultipleAssignments.Found"/>
	</rule>
	<rule ref="WordPress.CodeAnalysis.AssignmentInTernaryCondition">
		<exclude name="WordPress.CodeAnalysis.AssignmentInTernaryCondition.FoundInTernaryCondition"/>
	</rule>
	<!-- Duplicate array key and duplicate class: fix when found. -->
	<rule ref="Universal.Arrays.DuplicateArrayKey">
		<exclude name="Universal.Arrays.DuplicateArrayKey.Found"/>
	</rule>
	<rule ref="Generic.Classes.DuplicateClassName">
		<exclude name="Generic.Classes.DuplicateClassName.Found"/>
	</rule>
	<!-- Development/debug: error_log allowed in private distribution. -->
	<rule ref="WordPress.PHP.DevelopmentFunctions">
		<exclude name="WordPress.PHP.DevelopmentFunctions.error_log_error_log"/>
	</rule>
	<!-- Capabilities: custom caps not in WP core list. -->
	<rule ref="WordPress.WP.Capabilities">
		<exclude name="WordPress.WP.Capabilities.Unknown"/>
	</rule>
	<!-- PreparedSQL placeholders: complex dynamic queries. -->
	<rule ref="WordPress.DB.PreparedSQL">
		<exclude name="WordPress.DB.PreparedSQLPlaceholders.UnfinishedPrepare"/>
	</rule>
	<!-- Property naming: allow camelCase for JSON/dto-style. -->
	<rule ref="WordPress.NamingConventions.ValidVariableName">
		<exclude name="WordPress.NamingConventions.ValidVariableName.UsedPropertyNotSnakeCase"/>
	</rule>

	<config name="text_domain" value="aio-page-builder"/>
</ruleset>
